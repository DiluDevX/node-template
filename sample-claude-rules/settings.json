{
  "$schema": "https://cdn.jsdelivr.net/npm/@anthropic-ai/claude-code@latest/config-schema.json",
  "permissions": {
    "allow": [
      "Bash(yarn lint)",
      "Bash(yarn lint:fix)",
      "Bash(yarn format)",
      "Bash(yarn format:fix)",
      "Bash(yarn typecheck)",
      "Bash(yarn test)",
      "Bash(yarn test:unit)",
      "Bash(yarn test:e2e)",
      "Bash(yarn build)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(npx prettier --write*)",
      "Bash(gh *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.staging)",
      "Read(.env.prod)",
      "Read(.env.qa)",
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(yarn migrate:up:prod*)",
      "Bash(npm *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/format-file.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/validate-bash.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/stop-summary.sh"
          }
        ]
      }
    ]
  }
}
