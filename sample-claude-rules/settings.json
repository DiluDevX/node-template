{
  "$schema": "https://cdn.jsdelivr.net/npm/@anthropic-ai/claude-code@latest/config-schema.json",
  "permissions": {
    "allow": [
      "Bash(npm run lint:check)",
      "Bash(npm run lint:fix)",
      "Bash(npm run format:check)",
      "Bash(npm run format:fix)",
      "Bash(npm run types:check)",
      "Bash(npm run test*)",
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npm run prisma*)",
      "Bash(npm install*)",
      "Bash(npm ci)",
      "Bash(npm outdated)",
      "Bash(npm audit*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(npx prettier --write*)",
      "Bash(gh *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.staging)",
      "Read(.env.prod)",
      "Read(.env.qa)",
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(bun *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/format-file.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/validate-bash.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/stop-summary.sh"
          }
        ]
      }
    ]
  }
}
